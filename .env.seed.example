# Use a URL do seu projeto Supabase
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Chave service role (NUNCA usar no frontend)
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# Opcional: senha padrao dos usuarios seed
SEED_USER_PASSWORD=Music1234!

# Opcional: redefinir senha dos usuarios seed a cada execucao
SEED_RESET_PASSWORD=true
